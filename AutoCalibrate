/*
  ============================================================
  5 IR LINE FOLLOWER  —  AUTO-CALIBRATE + FULL FUNCTION EDITION
  ============================================================

  Features:
    ✔ Auto per-sensor calibration (samples black + white on startup)
    ✔ EEPROM save/load of all thresholds and speed parameters
    ✔ Dedicated functions: straight, steerLeft, steerRight,
      pivotLeft, pivotRight, turn90Left, turn90Right, turn315Right
    ✔ Serial command interface for live tuning (no reflash needed)
    ✔ PID-weighted position for smooth centre tracking
    ✔ Handles 90° left, 90° right, 315° right turns

  Serial Commands (9600 baud):
    CALIBRATE          — run full black/white calibration sequence
    STATUS             — print all current parameters
    SET BASE <n>       — base speed (0-255)
    SET FAST <n>       — fast side of gentle steer
    SET SLOW <n>       — slow side of gentle steer
    SET TURN <n>       — moderate pivot speed
    SET SHARP <n>      — sharp pivot speed
    SET RECOVER <n>    — recovery pivot speed
    SET SEARCH <n>     — search pivot speed
    SET TIMEOUT_L <ms> — recovery timeout for left turns
    SET TIMEOUT_R <ms> — recovery timeout for right (315°) turns
    SET KP <f>         — PID proportional gain (e.g. 12.0)
    SET KD <f>         — PID derivative gain  (e.g. 8.0)
    SAVE               — save all params to EEPROM
    LOAD               — reload params from EEPROM

  Wiring:
    ENA / IN1 / IN2 → PHYSICAL RIGHT motor
    ENB / IN3 / IN4 → PHYSICAL LEFT  motor
    S1=A0 S2=A1 S3=A2 S4=A3 S5=A4  (left to right)
  ============================================================
*/

#include <EEPROM.h>

// ─────────────────────────────────────────────
//  PIN DEFINITIONS
// ─────────────────────────────────────────────
const int IR_PIN[5] = { A0, A1, A2, A3, A4 };   // S1…S5 left→right

//  ENA/IN1/IN2 = physical RIGHT motor
//  ENB/IN3/IN4 = physical LEFT  motor
const int ENA = 5;   const int IN1 = 22;   const int IN2 = 23;
const int ENB = 6;   const int IN3 = 24;   const int IN4 = 25;

#define PHYS_RIGHT_INVERT false   // flip if right motor runs backwards
#define PHYS_LEFT_INVERT  false   // flip if left  motor runs backwards

// ─────────────────────────────────────────────
//  CALIBRATION DATA  (per-sensor)
// ─────────────────────────────────────────────
int calBlack[5];    // raw reading on black surface
int calWhite[5];    // raw reading on white surface
int calThresh[5];   // midpoint threshold (auto-set)

// EEPROM layout
#define EEPROM_MAGIC      0xAB
#define EEPROM_ADDR_MAGIC 0
#define EEPROM_ADDR_CAL   1       // 5×2×2 = 20 bytes  (black+white, int each)
#define EEPROM_ADDR_PARAMS 41     // params block

// ─────────────────────────────────────────────
//  TUNABLE PARAMETERS  (all live-adjustable)
// ─────────────────────────────────────────────
struct Params {
  int   baseSpeed;
  int   fastSpeed;
  int   slowSpeed;
  int   turnSpeed;
  int   sharpSpeed;
  int   recoverSpeed;
  int   searchSpeed;
  unsigned long timeoutLeft;    // ms — 90° left recovery
  unsigned long timeoutRight;   // ms — up to 315° right recovery
  float kp;                     // PID proportional
  float kd;                     // PID derivative
};

Params P = {
  70,    // baseSpeed
  95,    // fastSpeed
  50,    // slowSpeed
  85,    // turnSpeed
  100,   // sharpSpeed
  80,    // recoverSpeed
  70,    // searchSpeed
  1600,  // timeoutLeft
  4000,  // timeoutRight
  12.0f, // kp
  8.0f   // kd
};

// ─────────────────────────────────────────────
//  SENSOR STATE
// ─────────────────────────────────────────────
bool   S[5];          // true = white
int    raw[5];        // raw ADC values
// Weighted position:  -4 (far left) … +4 (far right), 0 = centre
// Weights: S1=-4, S2=-2, S3=0, S4=+2, S5=+4
const int WEIGHT[5] = { -4, -2, 0, 2, 4 };

float  pidPos      = 0;
float  lastPidPos  = 0;
float  pidError    = 0;
float  lastError   = 0;

// ─────────────────────────────────────────────
//  RECOVERY STATE
// ─────────────────────────────────────────────
enum RecDir { REC_NONE, REC_LEFT, REC_RIGHT };
RecDir recMode   = REC_NONE;
RecDir lastEdge  = REC_NONE;
unsigned long recStartMs = 0;

// ─────────────────────────────────────────────
//  RAW MOTOR PRIMITIVES
//  (ENA = physical right, ENB = physical left)
// ─────────────────────────────────────────────
void _rightFwd(int s) {
  s = constrain(s, 0, 255);
  if (!PHYS_RIGHT_INVERT) { digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH); }
  else                    { digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW);  }
  analogWrite(ENA, s);
}
void _rightBwd(int s) {
  s = constrain(s, 0, 255);
  if (!PHYS_RIGHT_INVERT) { digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW);  }
  else                    { digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH); }
  analogWrite(ENA, s);
}
void _leftFwd(int s) {
  s = constrain(s, 0, 255);
  if (!PHYS_LEFT_INVERT) { digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH); }
  else                   { digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW);  }
  analogWrite(ENB, s);
}
void _leftBwd(int s) {
  s = constrain(s, 0, 255);
  if (!PHYS_LEFT_INVERT) { digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW);  }
  else                   { digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH); }
  analogWrite(ENB, s);
}

// ─────────────────────────────────────────────
//  HIGH-LEVEL MOVEMENT FUNCTIONS
// ─────────────────────────────────────────────

void stopMotors() {
  analogWrite(ENA, 0); digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
  analogWrite(ENB, 0); digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
}

// Both wheels forward at same speed
void driveStraight(int spd) {
  _rightFwd(spd);
  _leftFwd(spd);
}

// Arc left: right wheel faster, left wheel slower
void steerLeft(int fast, int slow) {
  _rightFwd(fast);
  _leftFwd(slow);
}

// Arc right: left wheel faster, right wheel slower
void steerRight(int fast, int slow) {
  _rightFwd(slow);
  _leftFwd(fast);
}

// Pivot left in place: right fwd, left bwd
void pivotLeft(int spd) {
  _rightFwd(spd);
  _leftBwd(spd);
}

// Pivot right in place: left fwd, right bwd
void pivotRight(int spd) {
  _rightBwd(spd);
  _leftFwd(spd);
}

// ─── DEDICATED CORNER FUNCTIONS ──────────────────────────────────────────────

// 90° LEFT turn
//   Robot pivots left until S3 or S4 picks up the line again (or timeout).
void turn90Left() {
  unsigned long start = millis();
  Serial.println("[TURN] 90° LEFT start");
  while (millis() - start < (unsigned long)(P.timeoutLeft)) {
    readSensors();
    // Line found on centre/right side → done
    if (S[2] || S[3] || S[4]) break;
    pivotLeft(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
  Serial.println("[TURN] 90° LEFT done");
}

// 90° RIGHT turn
//   Robot pivots right until S1/S2/S3 picks up the line (or timeout).
void turn90Right() {
  unsigned long start = millis();
  Serial.println("[TURN] 90° RIGHT start");
  while (millis() - start < (unsigned long)(P.timeoutLeft)) {  // same duration as left 90°
    readSensors();
    if (S[0] || S[1] || S[2]) break;
    pivotRight(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
  Serial.println("[TURN] 90° RIGHT done");
}

// 315° RIGHT turn (nearly a full circle right)
//   Robot pivots right for up to timeoutRight ms.
//   Line will reappear from the LEFT side (S1/S2) after ~315°.
void turn315Right() {
  unsigned long start = millis();
  Serial.println("[TURN] 315° RIGHT start");
  // Phase 1: spin past the junction (brief dead zone, ~200 ms at sharpSpeed)
  // so we don't quit immediately on the departing line
  unsigned long deadZone = 200UL;
  while (millis() - start < deadZone) {
    pivotRight(P.sharpSpeed);
    delay(5);
  }
  // Phase 2: keep spinning until line reappears or timeout
  while (millis() - start < (unsigned long)(P.timeoutRight)) {
    readSensors();
    if (S[0] || S[1] || S[2] || S[3]) break;
    pivotRight(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
  Serial.println("[TURN] 315° RIGHT done");
}

// ─────────────────────────────────────────────
//  SENSOR READING
// ─────────────────────────────────────────────
void readSensors() {
  for (int i = 0; i < 5; i++) {
    raw[i] = analogRead(IR_PIN[i]);
    S[i]   = (raw[i] <= calThresh[i]);   // true = white
  }
}

bool allDark() {
  return !S[0] && !S[1] && !S[2] && !S[3] && !S[4];
}
bool anyWhite() {
  return S[0] || S[1] || S[2] || S[3] || S[4];
}

// Compute weighted position (-4…+4). Returns 0 if nothing seen.
float computePosition() {
  int sumW = 0, sumSeen = 0;
  for (int i = 0; i < 5; i++) {
    if (S[i]) { sumW += WEIGHT[i]; sumSeen++; }
  }
  if (sumSeen == 0) return lastPidPos;   // hold last known
  float pos = (float)sumW / sumSeen;
  lastPidPos = pos;
  return pos;
}

// ─────────────────────────────────────────────
//  CALIBRATION
// ─────────────────────────────────────────────
void calibrateSensors() {
  Serial.println("=== CALIBRATION START ===");
  Serial.println("Place robot on BLACK surface, then send any key...");
  while (!Serial.available()) delay(50);
  while (Serial.available()) Serial.read();   // flush

  // Sample black
  long acc[5] = {0,0,0,0,0};
  for (int r = 0; r < 50; r++) {
    for (int i = 0; i < 5; i++) acc[i] += analogRead(IR_PIN[i]);
    delay(10);
  }
  for (int i = 0; i < 5; i++) calBlack[i] = acc[i] / 50;
  Serial.print("BLACK:  ");
  for (int i = 0; i < 5; i++) { Serial.print(calBlack[i]); Serial.print(" "); }
  Serial.println();

  Serial.println("Place robot on WHITE line, then send any key...");
  while (!Serial.available()) delay(50);
  while (Serial.available()) Serial.read();

  // Sample white
  long acc2[5] = {0,0,0,0,0};
  for (int r = 0; r < 50; r++) {
    for (int i = 0; i < 5; i++) acc2[i] += analogRead(IR_PIN[i]);
    delay(10);
  }
  for (int i = 0; i < 5; i++) calWhite[i] = acc2[i] / 50;
  Serial.print("WHITE:  ");
  for (int i = 0; i < 5; i++) { Serial.print(calWhite[i]); Serial.print(" "); }
  Serial.println();

  // Set thresholds at midpoint
  for (int i = 0; i < 5; i++) {
    calThresh[i] = (calBlack[i] + calWhite[i]) / 2;
  }
  Serial.print("THRESH: ");
  for (int i = 0; i < 5; i++) { Serial.print(calThresh[i]); Serial.print(" "); }
  Serial.println();
  Serial.println("=== CALIBRATION DONE ===");
}

// ─────────────────────────────────────────────
//  EEPROM SAVE / LOAD
// ─────────────────────────────────────────────
void saveToEEPROM() {
  EEPROM.write(EEPROM_ADDR_MAGIC, EEPROM_MAGIC);
  int addr = EEPROM_ADDR_CAL;
  for (int i = 0; i < 5; i++) {
    EEPROM.put(addr, calBlack[i]); addr += sizeof(int);
    EEPROM.put(addr, calWhite[i]); addr += sizeof(int);
    EEPROM.put(addr, calThresh[i]); addr += sizeof(int);
  }
  EEPROM.put(EEPROM_ADDR_PARAMS, P);
  Serial.println("[EEPROM] Saved.");
}

bool loadFromEEPROM() {
  if (EEPROM.read(EEPROM_ADDR_MAGIC) != EEPROM_MAGIC) return false;
  int addr = EEPROM_ADDR_CAL;
  for (int i = 0; i < 5; i++) {
    EEPROM.get(addr, calBlack[i]);  addr += sizeof(int);
    EEPROM.get(addr, calWhite[i]);  addr += sizeof(int);
    EEPROM.get(addr, calThresh[i]); addr += sizeof(int);
  }
  EEPROM.get(EEPROM_ADDR_PARAMS, P);
  Serial.println("[EEPROM] Loaded.");
  return true;
}

// ─────────────────────────────────────────────
//  SERIAL COMMAND PARSER
// ─────────────────────────────────────────────
void printStatus() {
  Serial.println("─── PARAMS ───────────────────────────");
  Serial.print("BASE=");        Serial.print(P.baseSpeed);
  Serial.print("  FAST=");      Serial.print(P.fastSpeed);
  Serial.print("  SLOW=");      Serial.println(P.slowSpeed);
  Serial.print("TURN=");        Serial.print(P.turnSpeed);
  Serial.print("  SHARP=");     Serial.print(P.sharpSpeed);
  Serial.print("  RECOVER=");   Serial.print(P.recoverSpeed);
  Serial.print("  SEARCH=");    Serial.println(P.searchSpeed);
  Serial.print("TIMEOUT_L=");   Serial.print(P.timeoutLeft);
  Serial.print("ms  TIMEOUT_R="); Serial.print(P.timeoutRight); Serial.println("ms");
  Serial.print("KP=");          Serial.print(P.kp);
  Serial.print("  KD=");        Serial.println(P.kd);
  Serial.println("─── THRESHOLDS ───────────────────────");
  for (int i = 0; i < 5; i++) {
    Serial.print("S"); Serial.print(i+1);
    Serial.print(": black="); Serial.print(calBlack[i]);
    Serial.print(" white=");  Serial.print(calWhite[i]);
    Serial.print(" thresh="); Serial.println(calThresh[i]);
  }
  Serial.println("──────────────────────────────────────");
}

void handleSerial() {
  if (!Serial.available()) return;
  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toUpperCase();

  if (cmd == "CALIBRATE") {
    calibrateSensors();
  } else if (cmd == "STATUS") {
    printStatus();
  } else if (cmd == "SAVE") {
    saveToEEPROM();
  } else if (cmd == "LOAD") {
    if (loadFromEEPROM()) printStatus();
    else Serial.println("[EEPROM] No saved data.");
  } else if (cmd.startsWith("SET ")) {
    // SET <KEY> <VALUE>
    int sp1 = cmd.indexOf(' ', 4);
    if (sp1 < 0) { Serial.println("Usage: SET KEY VALUE"); return; }
    String key = cmd.substring(4, sp1);
    String val = cmd.substring(sp1 + 1);
    val.trim();

    if      (key == "BASE")      P.baseSpeed    = val.toInt();
    else if (key == "FAST")      P.fastSpeed    = val.toInt();
    else if (key == "SLOW")      P.slowSpeed    = val.toInt();
    else if (key == "TURN")      P.turnSpeed    = val.toInt();
    else if (key == "SHARP")     P.sharpSpeed   = val.toInt();
    else if (key == "RECOVER")   P.recoverSpeed = val.toInt();
    else if (key == "SEARCH")    P.searchSpeed  = val.toInt();
    else if (key == "TIMEOUT_L") P.timeoutLeft  = val.toInt();
    else if (key == "TIMEOUT_R") P.timeoutRight = val.toInt();
    else if (key == "KP")        P.kp           = val.toFloat();
    else if (key == "KD")        P.kd           = val.toFloat();
    else { Serial.print("Unknown key: "); Serial.println(key); return; }

    Serial.print("[SET] "); Serial.print(key); Serial.print(" = "); Serial.println(val);
  } else {
    Serial.println("Commands: CALIBRATE | STATUS | SAVE | LOAD | SET KEY VALUE");
  }
}

// ─────────────────────────────────────────────
//  PID LINE FOLLOWING  (called each loop tick)
// ─────────────────────────────────────────────
void followLine() {
  pidPos   = computePosition();
  pidError = pidPos;   // 0 = centred, negative = drifted right, positive = drifted left

  float derivative = pidError - lastError;
  float correction = P.kp * pidError + P.kd * derivative;
  lastError = pidError;

  int leftSpd  = constrain((int)(P.baseSpeed + correction), 0, 255);
  int rightSpd = constrain((int)(P.baseSpeed - correction), 0, 255);

  // correction > 0 → drifted left → speed up left, slow right  → arc right
  // correction < 0 → drifted right → speed up right, slow left → arc left
  _rightFwd(rightSpd);
  _leftFwd(leftSpd);
}

// ─────────────────────────────────────────────
//  RECOVERY FUNCTION
// ─────────────────────────────────────────────
void doRecovery() {
  if (recMode == REC_NONE) return;

  if (anyWhite()) {
    recMode = REC_NONE;
    return;
  }

  unsigned long elapsed = millis() - recStartMs;
  unsigned long limit   = (recMode == REC_LEFT) ? P.timeoutLeft : P.timeoutRight;

  if (elapsed > limit) {
    recMode = REC_NONE;
    return;
  }

  if (recMode == REC_LEFT)  pivotLeft(P.recoverSpeed);
  else                      pivotRight(P.recoverSpeed);
}

// ─────────────────────────────────────────────
//  SETUP
// ─────────────────────────────────────────────
void setup() {
  Serial.begin(9600);

  pinMode(ENA, OUTPUT); pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT);
  pinMode(ENB, OUTPUT); pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  stopMotors();

  // Default thresholds (safe fallback if never calibrated)
  for (int i = 0; i < 5; i++) {
    calBlack[i] = 600;
    calWhite[i] = 100;
    calThresh[i] = 300;
  }

  // Try to load saved calibration + params from EEPROM
  if (!loadFromEEPROM()) {
    Serial.println("[BOOT] No EEPROM data. Using defaults.");
    Serial.println("[BOOT] Send CALIBRATE to calibrate sensors.");
    Serial.println("[BOOT] Send STATUS to view all parameters.");
  } else {
    printStatus();
  }

  delay(1000);
  Serial.println("[BOOT] Running.");
}

// ─────────────────────────────────────────────
//  MAIN LOOP
// ─────────────────────────────────────────────
void loop() {

  // Handle any incoming Serial commands (non-blocking)
  handleSerial();

  // Read all 5 IR sensors
  readSensors();

  bool dark = allDark();

  // ── Update last-edge memory ──────────────────────────────────────
  if (S[0] || S[1])                         lastEdge = REC_LEFT;
  if (S[3] || S[4])                         lastEdge = REC_RIGHT;
  if (S[2] && !S[0] && !S[1] && !S[3] && !S[4]) lastEdge = REC_NONE;

  // ── Enter recovery on line loss ─────────────────────────────────
  if (recMode == REC_NONE && dark) {
    if      (lastEdge == REC_LEFT)  { recMode = REC_LEFT;  recStartMs = millis(); }
    else if (lastEdge == REC_RIGHT) { recMode = REC_RIGHT; recStartMs = millis(); }
  }

  // ── Recovery mode ───────────────────────────────────────────────
  if (recMode != REC_NONE) {
    doRecovery();
    if (recMode != REC_NONE) {   // still in recovery after doRecovery()
      delay(5);
      return;
    }
    // recMode was cleared inside doRecovery() → fall through to normal follow
  }

  // ── Normal line following (PID) ──────────────────────────────────
  if (!dark) {
    followLine();
  } else {
    // Full loss — spin toward last known edge
    if      (lastEdge == REC_LEFT)  pivotLeft(P.searchSpeed);
    else if (lastEdge == REC_RIGHT) pivotRight(P.searchSpeed);
    else                            driveStraight(P.baseSpeed);
  }

  delay(5);   // 200 Hz loop
}
