/*
  =========================================================================
  5 IR LINE FOLLOWER
  AUTO CALIBRATE + EEPROM + ANALOG PID + WIDTH ADAPT + SMART RECOVERY
  =========================================================================

  NEW RECOVERY LOGIC:
    1. If all sensors dark -> reverse using memory bias
    2. Then move forward a little
    3. Then detect committed turn groups:
         LEFT  : 10000 / 11000 / 11100
         RIGHT : 00001 / 00011 / 00111
    4. Keep turning until path is found again

  SERIAL COMMANDS:
    CALIBRATE
    STATUS
    SAVE
    LOAD

    SET BASE <n>
    SET FAST <n>
    SET SLOW <n>
    SET TURN <n>
    SET SHARP <n>
    SET RECOVER <n>
    SET SEARCH <n>
    SET REVERSE <n>
    SET REVERSE_BIAS <n>
    SET FORWARD_REC <n>
    SET MINSPEED <n>
    SET TIMEOUT_L <ms>
    SET TIMEOUT_R <ms>
    SET FORWARD_TIME <ms>
    SET KP <f>
    SET KD <f>
    SET FILTER <f>
    SET WIDTHKP <f>
    SET LTRIM <n>
    SET RTRIM <n>
*/

#include <EEPROM.h>

// ─────────────────────────────────────────────
// FUNCTION PROTOTYPES
// ─────────────────────────────────────────────
void stopMotors();
void driveStraight(int spd);
void driveBackward(int spd);
void driveBackwardBiasLeft(int fast, int slow);
void driveBackwardBiasRight(int fast, int slow);
void driveForwardRecovery(int spd);
void steerLeft(int fast, int slow);
void steerRight(int fast, int slow);
void pivotLeft(int spd);
void pivotRight(int spd);

void readSensors();
bool allDark();
bool anyWhite();
int  sensorBits();
bool isLeftTurnPattern();
bool isRightTurnPattern();
bool isPathFoundPattern();

float computeAnalogPosition();
float computeLineWidthEstimate();

void calibrateSensors();
void saveToEEPROM();
bool loadFromEEPROM();

void printStatus();
void handleSerial();

void followLine();
void turn90Left();
void turn90Right();
void turn315Right();

void runLostLineRecovery();
void resetRecoveryState();
void updateLastSeenSide();

void recoveryReverseStage();
void recoveryForwardStage();
void recoveryTurnLeftStage();
void recoveryTurnRightStage();

// ─────────────────────────────────────────────
// PIN DEFINITIONS
// ─────────────────────────────────────────────
const int IR_PIN[5] = { A0, A1, A2, A3, A4 };  // S1..S5 left -> right

const int ENA = 5;   // physical RIGHT motor PWM
const int IN1 = 22;
const int IN2 = 23;

const int ENB = 6;   // physical LEFT motor PWM
const int IN3 = 24;
const int IN4 = 25;

#define PHYS_RIGHT_INVERT false
#define PHYS_LEFT_INVERT  false

// ─────────────────────────────────────────────
// CALIBRATION DATA
// ─────────────────────────────────────────────
int calBlack[5];
int calWhite[5];
int calThresh[5];
int strength[5];
int raw[5];
bool S[5];

// EEPROM layout
#define EEPROM_MAGIC       0xAB
#define EEPROM_ADDR_MAGIC  0
#define EEPROM_ADDR_CAL    1
#define EEPROM_ADDR_PARAMS 100

// ─────────────────────────────────────────────
// PARAMETERS
// ─────────────────────────────────────────────
struct Params {
  int   baseSpeed;
  int   fastSpeed;
  int   slowSpeed;
  int   turnSpeed;
  int   sharpSpeed;
  int   recoverSpeed;
  int   searchSpeed;
  int   reverseSpeed;
  int   reverseBiasDelta;
  int   forwardRecoverSpeed;
  int   minSpeed;

  unsigned long timeoutLeft;
  unsigned long timeoutRight;
  unsigned long forwardRecoverTime;

  float kp;
  float kd;
  float posFilter;
  float widthKp;

  int leftTrim;
  int rightTrim;
};

Params P = {
  78,      // baseSpeed
  100,     // fastSpeed
  52,      // slowSpeed
  88,      // turnSpeed
  108,     // sharpSpeed
  82,      // recoverSpeed
  72,      // searchSpeed
  58,      // reverseSpeed
  18,      // reverseBiasDelta
  60,      // forwardRecoverSpeed
  40,      // minSpeed

  1800,    // timeoutLeft
  4000,    // timeoutRight
  160,     // forwardRecoverTime (ms)

  16.0f,   // kp
  10.0f,   // kd
  0.65f,   // posFilter
  6.0f,    // widthKp

  8,       // leftTrim -> slight right bias
  0        // rightTrim
};

// ─────────────────────────────────────────────
// SENSOR / PID STATE
// ─────────────────────────────────────────────
const int WEIGHT[5] = { -4, -2, 0, 2, 4 };

float pidPos       = 0.0f;
float filteredPos  = 0.0f;
float lastPidPos   = 0.0f;
float pidError     = 0.0f;
float lastError    = 0.0f;
float lineWidthEst = 0.0f;

// ─────────────────────────────────────────────
// MEMORY OF LAST SEEN SIDE
// ─────────────────────────────────────────────
enum SeenSide {
  SIDE_UNKNOWN,
  SIDE_LEFT,
  SIDE_CENTER,
  SIDE_RIGHT
};

SeenSide lastSeenSide = SIDE_UNKNOWN;

// ─────────────────────────────────────────────
// LOST-LINE RECOVERY STATE
// ─────────────────────────────────────────────
enum RecoveryMode {
  REC_IDLE,
  REC_REVERSE,
  REC_FORWARD_CHECK,
  REC_TURN_LEFT,
  REC_TURN_RIGHT
};

RecoveryMode recMode = REC_IDLE;
unsigned long recStartMs = 0;

// ─────────────────────────────────────────────
// LOW LEVEL MOTOR PRIMITIVES WITH TRIM
// ─────────────────────────────────────────────
void _rightFwd(int s) {
  s = constrain(s + P.rightTrim, 0, 255);
  if (!PHYS_RIGHT_INVERT) {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
  } else {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  }
  analogWrite(ENA, s);
}

void _rightBwd(int s) {
  s = constrain(s + P.rightTrim, 0, 255);
  if (!PHYS_RIGHT_INVERT) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
  }
  analogWrite(ENA, s);
}

void _leftFwd(int s) {
  s = constrain(s + P.leftTrim, 0, 255);
  if (!PHYS_LEFT_INVERT) {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
  } else {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  }
  analogWrite(ENB, s);
}

void _leftBwd(int s) {
  s = constrain(s + P.leftTrim, 0, 255);
  if (!PHYS_LEFT_INVERT) {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
  }
  analogWrite(ENB, s);
}

// ─────────────────────────────────────────────
// HIGH LEVEL MOVEMENT
// ─────────────────────────────────────────────
void stopMotors() {
  analogWrite(ENA, 0);
  analogWrite(ENB, 0);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

void driveStraight(int spd) {
  _rightFwd(spd);
  _leftFwd(spd);
}

void driveForwardRecovery(int spd) {
  _rightFwd(spd);
  _leftFwd(spd);
}

void driveBackward(int spd) {
  _rightBwd(spd);
  _leftBwd(spd);
}

// left bias while reversing
void driveBackwardBiasLeft(int fast, int slow) {
  _rightBwd(slow);
  _leftBwd(fast);
}

// right bias while reversing
void driveBackwardBiasRight(int fast, int slow) {
  _rightBwd(fast);
  _leftBwd(slow);
}

void steerLeft(int fast, int slow) {
  _rightFwd(fast);
  _leftFwd(slow);
}

void steerRight(int fast, int slow) {
  _rightFwd(slow);
  _leftFwd(fast);
}

void pivotLeft(int spd) {
  _rightFwd(spd);
  _leftBwd(spd);
}

void pivotRight(int spd) {
  _rightBwd(spd);
  _leftFwd(spd);
}

// ─────────────────────────────────────────────
// SENSOR READING
// ─────────────────────────────────────────────
void readSensors() {
  for (int i = 0; i < 5; i++) {
    raw[i] = analogRead(IR_PIN[i]);
    S[i] = (raw[i] <= calThresh[i]);

    int whiteRef = calWhite[i];
    int blackRef = calBlack[i];

    if (blackRef <= whiteRef + 5) blackRef = whiteRef + 50;

    long st = map(raw[i], blackRef, whiteRef, 0, 1000);
    strength[i] = constrain((int)st, 0, 1000);
  }
}

bool allDark() {
  return !S[0] && !S[1] && !S[2] && !S[3] && !S[4];
}

bool anyWhite() {
  return S[0] || S[1] || S[2] || S[3] || S[4];
}

int sensorBits() {
  return (S[0] ? 16 : 0) |
         (S[1] ?  8 : 0) |
         (S[2] ?  4 : 0) |
         (S[3] ?  2 : 0) |
         (S[4] ?  1 : 0);
}

// LEFT if detect 10000 or 11000 or 11100
bool isLeftTurnPattern() {
  int b = sensorBits();
  return (b == 0b10000 || b == 0b11000 || b == 0b11100);
}

// RIGHT if detect 00001 or 00011 or 00111
bool isRightTurnPattern() {
  int b = sensorBits();
  return (b == 0b00001 || b == 0b00011 || b == 0b00111);
}

// path found enough to resume normal PID
bool isPathFoundPattern() {
  int b = sensorBits();

  return (
    b == 0b00100 ||
    b == 0b01100 ||
    b == 0b00110 ||
    b == 0b01110 ||
    b == 0b01000 ||
    b == 0b00010
  );
}

float computeAnalogPosition() {
  long weightedSum = 0;
  long total = 0;

  for (int i = 0; i < 5; i++) {
    weightedSum += (long)WEIGHT[i] * (long)strength[i];
    total += (long)strength[i];
  }

  if (total < 50) return lastPidPos;

  float pos = (float)weightedSum / (float)total;
  lastPidPos = pos;
  return pos;
}

float computeLineWidthEstimate() {
  long total = 0;
  int activeCount = 0;

  for (int i = 0; i < 5; i++) {
    total += strength[i];
    if (strength[i] > 250) activeCount++;
  }

  return activeCount + (float)total / 5000.0f;
}

// ─────────────────────────────────────────────
// MEMORY UPDATE
// ─────────────────────────────────────────────
void updateLastSeenSide() {
  if (S[0] || S[1]) lastSeenSide = SIDE_LEFT;
  if (S[3] || S[4]) lastSeenSide = SIDE_RIGHT;

  if (S[2] && !S[0] && !S[1] && !S[3] && !S[4]) {
    lastSeenSide = SIDE_CENTER;
  }

  if (S[0]) lastSeenSide = SIDE_LEFT;
  if (S[4]) lastSeenSide = SIDE_RIGHT;
}

// ─────────────────────────────────────────────
// CALIBRATION
// ─────────────────────────────────────────────
void calibrateSensors() {
  Serial.println("=== CALIBRATION START ===");
  Serial.println("Place robot on BLACK surface, then send any key...");
  while (!Serial.available()) delay(50);
  while (Serial.available()) Serial.read();

  long accB[5] = {0, 0, 0, 0, 0};
  for (int r = 0; r < 60; r++) {
    for (int i = 0; i < 5; i++) accB[i] += analogRead(IR_PIN[i]);
    delay(10);
  }
  for (int i = 0; i < 5; i++) calBlack[i] = accB[i] / 60;

  Serial.println("Place robot on WHITE line, then send any key...");
  while (!Serial.available()) delay(50);
  while (Serial.available()) Serial.read();

  long accW[5] = {0, 0, 0, 0, 0};
  for (int r = 0; r < 60; r++) {
    for (int i = 0; i < 5; i++) accW[i] += analogRead(IR_PIN[i]);
    delay(10);
  }
  for (int i = 0; i < 5; i++) calWhite[i] = accW[i] / 60;

  for (int i = 0; i < 5; i++) {
    calThresh[i] = (calBlack[i] + calWhite[i]) / 2;
  }

  Serial.println("=== CALIBRATION DONE ===");
}

// ─────────────────────────────────────────────
// EEPROM
// ─────────────────────────────────────────────
void saveToEEPROM() {
  EEPROM.write(EEPROM_ADDR_MAGIC, EEPROM_MAGIC);

  int addr = EEPROM_ADDR_CAL;
  for (int i = 0; i < 5; i++) {
    EEPROM.put(addr, calBlack[i]);  addr += sizeof(int);
    EEPROM.put(addr, calWhite[i]);  addr += sizeof(int);
    EEPROM.put(addr, calThresh[i]); addr += sizeof(int);
  }

  EEPROM.put(EEPROM_ADDR_PARAMS, P);
  Serial.println("[EEPROM] Saved.");
}

bool loadFromEEPROM() {
  if (EEPROM.read(EEPROM_ADDR_MAGIC) != EEPROM_MAGIC) return false;

  int addr = EEPROM_ADDR_CAL;
  for (int i = 0; i < 5; i++) {
    EEPROM.get(addr, calBlack[i]);  addr += sizeof(int);
    EEPROM.get(addr, calWhite[i]);  addr += sizeof(int);
    EEPROM.get(addr, calThresh[i]); addr += sizeof(int);
  }

  EEPROM.get(EEPROM_ADDR_PARAMS, P);
  Serial.println("[EEPROM] Loaded.");
  return true;
}

// ─────────────────────────────────────────────
// SERIAL COMMANDS
// ─────────────────────────────────────────────
void printStatus() {
  Serial.println("──────── PARAMETERS ────────");
  Serial.print("BASE="); Serial.print(P.baseSpeed);
  Serial.print(" FAST="); Serial.print(P.fastSpeed);
  Serial.print(" SLOW="); Serial.println(P.slowSpeed);

  Serial.print("TURN="); Serial.print(P.turnSpeed);
  Serial.print(" SHARP="); Serial.print(P.sharpSpeed);
  Serial.print(" RECOVER="); Serial.print(P.recoverSpeed);
  Serial.print(" SEARCH="); Serial.print(P.searchSpeed);
  Serial.print(" REVERSE="); Serial.print(P.reverseSpeed);
  Serial.print(" REVERSE_BIAS="); Serial.print(P.reverseBiasDelta);
  Serial.print(" FORWARD_REC="); Serial.print(P.forwardRecoverSpeed);
  Serial.print(" MINSPEED="); Serial.println(P.minSpeed);

  Serial.print("TIMEOUT_L="); Serial.print(P.timeoutLeft);
  Serial.print(" TIMEOUT_R="); Serial.print(P.timeoutRight);
  Serial.print(" FORWARD_TIME="); Serial.println(P.forwardRecoverTime);

  Serial.print("KP="); Serial.print(P.kp);
  Serial.print(" KD="); Serial.print(P.kd);
  Serial.print(" FILTER="); Serial.print(P.posFilter);
  Serial.print(" WIDTHKP="); Serial.println(P.widthKp);

  Serial.print("LTRIM="); Serial.print(P.leftTrim);
  Serial.print(" RTRIM="); Serial.println(P.rightTrim);

  Serial.print("LAST_SEEN_SIDE=");
  if      (lastSeenSide == SIDE_LEFT)   Serial.println("LEFT");
  else if (lastSeenSide == SIDE_RIGHT)  Serial.println("RIGHT");
  else if (lastSeenSide == SIDE_CENTER) Serial.println("CENTER");
  else                                  Serial.println("UNKNOWN");
}

void handleSerial() {
  if (!Serial.available()) return;

  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toUpperCase();

  if (cmd == "CALIBRATE") {
    calibrateSensors();
    return;
  }

  if (cmd == "STATUS") {
    printStatus();
    return;
  }

  if (cmd == "SAVE") {
    saveToEEPROM();
    return;
  }

  if (cmd == "LOAD") {
    if (loadFromEEPROM()) printStatus();
    else Serial.println("[EEPROM] No saved data.");
    return;
  }

  if (cmd.startsWith("SET ")) {
    int sp1 = cmd.indexOf(' ', 4);
    if (sp1 < 0) {
      Serial.println("Usage: SET KEY VALUE");
      return;
    }

    String key = cmd.substring(4, sp1);
    String val = cmd.substring(sp1 + 1);
    val.trim();

    if      (key == "BASE")          P.baseSpeed         = val.toInt();
    else if (key == "FAST")          P.fastSpeed         = val.toInt();
    else if (key == "SLOW")          P.slowSpeed         = val.toInt();
    else if (key == "TURN")          P.turnSpeed         = val.toInt();
    else if (key == "SHARP")         P.sharpSpeed        = val.toInt();
    else if (key == "RECOVER")       P.recoverSpeed      = val.toInt();
    else if (key == "SEARCH")        P.searchSpeed       = val.toInt();
    else if (key == "REVERSE")       P.reverseSpeed      = val.toInt();
    else if (key == "REVERSE_BIAS")  P.reverseBiasDelta  = val.toInt();
    else if (key == "FORWARD_REC")   P.forwardRecoverSpeed = val.toInt();
    else if (key == "MINSPEED")      P.minSpeed          = val.toInt();
    else if (key == "TIMEOUT_L")     P.timeoutLeft       = val.toInt();
    else if (key == "TIMEOUT_R")     P.timeoutRight      = val.toInt();
    else if (key == "FORWARD_TIME")  P.forwardRecoverTime = val.toInt();
    else if (key == "KP")            P.kp                = val.toFloat();
    else if (key == "KD")            P.kd                = val.toFloat();
    else if (key == "FILTER")        P.posFilter         = val.toFloat();
    else if (key == "WIDTHKP")       P.widthKp           = val.toFloat();
    else if (key == "LTRIM")         P.leftTrim          = val.toInt();
    else if (key == "RTRIM")         P.rightTrim         = val.toInt();
    else {
      Serial.print("Unknown key: ");
      Serial.println(key);
      return;
    }

    Serial.print("[SET] ");
    Serial.print(key);
    Serial.print(" = ");
    Serial.println(val);
    return;
  }

  Serial.println("Commands: CALIBRATE | STATUS | SAVE | LOAD | SET KEY VALUE");
}

// ─────────────────────────────────────────────
// TURN FUNCTIONS
// ─────────────────────────────────────────────
void turn90Left() {
  unsigned long start = millis();
  while (millis() - start < P.timeoutLeft) {
    readSensors();
    if (S[2] || S[3] || S[4]) break;
    pivotLeft(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
}

void turn90Right() {
  unsigned long start = millis();
  while (millis() - start < P.timeoutLeft) {
    readSensors();
    if (S[0] || S[1] || S[2]) break;
    pivotRight(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
}

void turn315Right() {
  unsigned long start = millis();
  unsigned long deadZone = 200;

  while (millis() - start < deadZone) {
    pivotRight(P.sharpSpeed);
    delay(5);
  }

  while (millis() - start < P.timeoutRight) {
    readSensors();
    if (S[0] || S[1] || S[2] || S[3]) break;
    pivotRight(P.sharpSpeed);
    delay(5);
  }
  stopMotors();
}

// ─────────────────────────────────────────────
// LINE FOLLOW
// ─────────────────────────────────────────────
void followLine() {
  pidPos = computeAnalogPosition();

  filteredPos = P.posFilter * filteredPos + (1.0f - P.posFilter) * pidPos;

  lineWidthEst = computeLineWidthEstimate();

  pidError = filteredPos;
  float derivative = pidError - lastError;

  float widthComp = 1.0f;
  if (lineWidthEst > 1.5f) {
    widthComp = 1.0f / (1.0f + P.widthKp * 0.08f * (lineWidthEst - 1.5f));
    if (widthComp < 0.45f) widthComp = 0.45f;
  }

  float correction = (P.kp * pidError + P.kd * derivative) * widthComp;
  lastError = pidError;

  int dynamicBase = P.baseSpeed - (int)(abs(pidError) * 8.0f);
  dynamicBase = constrain(dynamicBase, P.minSpeed, P.baseSpeed);

  int leftSpd  = constrain(dynamicBase + (int)correction, 0, 255);
  int rightSpd = constrain(dynamicBase - (int)correction, 0, 255);

  _rightFwd(rightSpd);
  _leftFwd(leftSpd);
}

// ─────────────────────────────────────────────
// RECOVERY HELPERS
// ─────────────────────────────────────────────
void resetRecoveryState() {
  recMode = REC_IDLE;
  recStartMs = 0;
}

void recoveryReverseStage() {
  int fastRev = constrain(P.reverseSpeed + P.reverseBiasDelta, 0, 255);
  int slowRev = constrain(P.reverseSpeed - P.reverseBiasDelta, 0, 255);

  if (lastSeenSide == SIDE_RIGHT) {
    driveBackwardBiasRight(fastRev, slowRev);
  } else if (lastSeenSide == SIDE_LEFT) {
    driveBackwardBiasLeft(fastRev, slowRev);
  } else {
    driveBackward(P.reverseSpeed);
  }

  readSensors();

  // once any white comes back, go to forward-check stage
  if (anyWhite()) {
    recMode = REC_FORWARD_CHECK;
    recStartMs = millis();
    return;
  }

  // fail-safe: too long reversing, still try forward-check
  if (millis() - recStartMs > P.timeoutRight) {
    recMode = REC_FORWARD_CHECK;
    recStartMs = millis();
    return;
  }
}

void recoveryForwardStage() {
  driveForwardRecovery(P.forwardRecoverSpeed);

  readSensors();

  // only after forwarding, decide committed turn
  if (isLeftTurnPattern()) {
    recMode = REC_TURN_LEFT;
    recStartMs = millis();
    return;
  }

  if (isRightTurnPattern()) {
    recMode = REC_TURN_RIGHT;
    recStartMs = millis();
    return;
  }

  // if already got usable path, resume PID
  if (isPathFoundPattern()) {
    resetRecoveryState();
    return;
  }

  // move forward only for limited time
  if (millis() - recStartMs > P.forwardRecoverTime) {
    // choose side by memory if no exact pattern found
    if (lastSeenSide == SIDE_LEFT) {
      recMode = REC_TURN_LEFT;
    } else if (lastSeenSide == SIDE_RIGHT) {
      recMode = REC_TURN_RIGHT;
    } else {
      resetRecoveryState();
    }
    recStartMs = millis();
    return;
  }
}

void recoveryTurnLeftStage() {
  pivotLeft(P.searchSpeed);

  readSensors();

  // keep turning left until path found
  if (isPathFoundPattern()) {
    resetRecoveryState();
    return;
  }

  // stay in left turn while left-group still appears
  if (isLeftTurnPattern()) {
    return;
  }

  // if timed out, fall back to reverse
  if (millis() - recStartMs > P.timeoutLeft) {
    recMode = REC_REVERSE;
    recStartMs = millis();
    return;
  }
}

void recoveryTurnRightStage() {
  pivotRight(P.searchSpeed);

  readSensors();

  // keep turning right until path found
  if (isPathFoundPattern()) {
    resetRecoveryState();
    return;
  }

  // stay in right turn while right-group still appears
  if (isRightTurnPattern()) {
    return;
  }

  // if timed out, fall back to reverse
  if (millis() - recStartMs > P.timeoutRight) {
    recMode = REC_REVERSE;
    recStartMs = millis();
    return;
  }
}

// ─────────────────────────────────────────────
// SMART LOST LINE RECOVERY
// ─────────────────────────────────────────────
void runLostLineRecovery() {
  readSensors();

  if (recMode == REC_IDLE) {
    recMode = REC_REVERSE;
    recStartMs = millis();
  }

  switch (recMode) {
    case REC_REVERSE:
      recoveryReverseStage();
      break;

    case REC_FORWARD_CHECK:
      recoveryForwardStage();
      break;

    case REC_TURN_LEFT:
      recoveryTurnLeftStage();
      break;

    case REC_TURN_RIGHT:
      recoveryTurnRightStage();
      break;

    default:
      recMode = REC_REVERSE;
      recStartMs = millis();
      break;
  }
}

// ─────────────────────────────────────────────
// SETUP
// ─────────────────────────────────────────────
void setup() {
  Serial.begin(9600);

  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  for (int i = 0; i < 5; i++) pinMode(IR_PIN[i], INPUT);

  stopMotors();

  for (int i = 0; i < 5; i++) {
    calBlack[i]  = 900;
    calWhite[i]  = 100;
    calThresh[i] = 500;
  }

  if (!loadFromEEPROM()) {
    Serial.println("[BOOT] No EEPROM data. Using defaults.");
    Serial.println("[BOOT] Send CALIBRATE");
    Serial.println("[BOOT] Send STATUS");
  } else {
    printStatus();
  }

  filteredPos = 0;
  lastPidPos = 0;
  lastError = 0;
  lastSeenSide = SIDE_UNKNOWN;
  resetRecoveryState();

  delay(1000);
  Serial.println("[BOOT] Running.");
}

// ─────────────────────────────────────────────
// MAIN LOOP
// ─────────────────────────────────────────────
void loop() {
  handleSerial();

  readSensors();

  if (!allDark()) {
    updateLastSeenSide();

    // if normal path found during recovery, clear recovery
    if (recMode != REC_IDLE && isPathFoundPattern()) {
      resetRecoveryState();
    }

    if (recMode == REC_IDLE) {
      followLine();
    } else {
      runLostLineRecovery();
    }
  } else {
    runLostLineRecovery();
  }

  delay(5);
}
